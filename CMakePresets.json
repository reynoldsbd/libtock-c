{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "Tock",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_MODULE_PATH": "${sourceDir}/cmake",
                "CMAKE_PROJECT_INCLUDE": "${sourceDir}/cmake/TockOptionalIncludes.cmake",
                "FETCHCONTENT_BASE_DIR": "${sourceDir}/build/deps",
                "TOCK_NEWLIB": "ON"
            }
        },
        {
            "name": "cortex-m",
            "hidden": true,
            "inherits": "base",
            "toolchainFile": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
            "cacheVariables": {
                "TOCK_NEWLIB_SUBDIR": "arm/arm-none-eabi"
            }
        },
        {
            "name": "cortex-m0",
            "displayName": "Cortex M0",
            "inherits": "cortex-m",
            "cacheVariables": {
                "CMAKE_SYSTEM_PROCESSOR": "armv6-m",
                "TOCK_ARM_CPU": "cortex-m0",
                "TOCK_NEWLIB_LIBDIR": "thumb/v6-m/nofp"
            }
        },
        {
            "name": "cortex-m3",
            "displayName": "Cortex M3",
            "inherits": "cortex-m",
            "cacheVariables": {
                "CMAKE_SYSTEM_PROCESSOR": "armv6-m",
                "TOCK_ARM_CPU": "cortex-m3",
                "TOCK_NEWLIB_LIBDIR": "thumb/v7-m/nofp"
            }
        },
        {
            "name": "cortex-m4",
            "displayName": "Cortex M4",
            "inherits": "cortex-m",
            "cacheVariables": {
                "CMAKE_SYSTEM_PROCESSOR": "armv7e-m",
                "TOCK_ARM_CPU": "cortex-m4",
                "TOCK_NEWLIB_LIBDIR": "thumb/v7e-m/nofp"
            }
        },
        {
            "name": "cortex-m7",
            "displayName": "Cortex M7",
            "inherits": "cortex-m",
            "cacheVariables": {
                "CMAKE_SYSTEM_PROCESSOR": "armv7e-m",
                "TOCK_ARM_CPU": "cortex-m7",
                "TOCK_NEWLIB_LIBDIR": "thumb/v7e-m/fp"
            }
        },
        {
            "name": "rv32",
            "hidden": true,
            "inherits": "base",
            "toolchainFile": "${sourceDir}/cmake/toolchains/riscv32-gcc.cmake"
        },
        {
            "name": "rv32imc",
            "displayName": "RISC-V 32 IMC",
            "inherits": "rv32",
            "cacheVariables": {
                "CMAKE_SYSTEM_PROCESSOR": "rv32imc"
            }
        },
        {
            "name": "rv32imac",
            "displayName": "RISC-V 32 IMAC",
            "inherits": "rv32",
            "cacheVariables": {
                "CMAKE_SYSTEM_PROCESSOR": "rv32imac"
            }
        }
        // todo: how to manage different rv memory maps?
        // todo: rv32-clang and friends
    ],
    "buildPresets": [
        {
            "name": "base",
            "hidden": true,
            "inheritConfigureEnvironment": true
        },
        {
            "name": "cortex-m0",
            "displayName": "Cortex M0",
            "inherits": "base",
            "configurePreset": "cortex-m0"
        },
        {
            "name": "cortex-m3",
            "displayName": "Cortex M3",
            "inherits": "base",
            "configurePreset": "cortex-m3"
        },
        {
            "name": "cortex-m4",
            "displayName": "Cortex M4",
            "inherits": "base",
            "configurePreset": "cortex-m4"
        },
        {
            "name": "cortex-m7",
            "displayName": "Cortex M7",
            "inherits": "base",
            "configurePreset": "cortex-m7"
        }
    ]
}
